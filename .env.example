# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Gmail sender address (default: francisanthony0328@gmail.com)
GMAIL_SENDER=francisanthony0328@gmail.com

# Path to your resume DOCX for tailoring (optional — enables per-company resume tailoring)
RESUME_DOCX_PATH=resume/Francis_Konikkara_Resume.docx

# Path to your resume PDF to attach directly (optional — used if DOCX tailoring not needed)
RESUME_PDF_PATH=resume/Francis_Konikkara_Resume.pdf

# Output directory for tailored resumes (default: resume_outputs/)
RESUME_OUTPUT_DIR=resume_outputs

# Number of emails to send per run (default: 10)
EMAILS_PER_RUN=10
